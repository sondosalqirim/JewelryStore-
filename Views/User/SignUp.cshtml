@model Web_project_as.Models.User
@{
    ViewData["Title"] = "Sign Up";
}
<h2>Sign Up</h2>
@if (ViewBag.Error != null)
{
    <p class="error">@ViewBag.Error</p>
}
<form method="post">
    <label asp-for="FullName">Full Name</label>
    <input asp-for="FullName" required />
    <label asp-for="Email">Email</label>
    <input asp-for="Email" type="email" required />
    <label asp-for="Password">Password</label>
    <input asp-for="Password" type="password" required />
    <button type="submit">Sign Up</button>
</form>
<p><a asp-action="SignIn">Already have an account? Sign In</a></p>
