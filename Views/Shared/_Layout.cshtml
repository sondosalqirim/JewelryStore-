<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Jewelry Store</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="nav">
        <div>
            <a asp-controller="Product" asp-action="ShowAllProudect">Products</a>
            <a asp-controller="Product" asp-action="SearchProduct">Search</a>
            <a asp-controller="Order" asp-action="ShowAllOrders">Orders</a>
            <a asp-controller="User" asp-action="ShowAllUsers">Users</a>
        </div>
        <div>
            @if (Context.Session.GetInt32("UserID") != null)
            {
                <a asp-controller="User" asp-action="Profile">@Context.Session.GetString("UserName")</a>
                <a asp-controller="User" asp-action="LogOut">Log Out</a>
            }
            else
            {
                <a asp-controller="User" asp-action="SignIn">Sign In</a>
                <a asp-controller="User" asp-action="SignUp">Sign Up</a>
            }
        </div>
    </nav>

    <div class="main">
        @RenderBody()
    </div>

    <div class="footer">
        &copy; 2026 Jewelry Store
    </div>
</body>
</html>
