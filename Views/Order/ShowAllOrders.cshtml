@model IEnumerable<Web_project_as.Models.Order>
@{
    ViewData["Title"] = "Show All Orders";
}
<div class="container mt-4">
    <h2>Orders List</h2>
    <table class="table table-bordered table-striped mt-3">
        <thead class="table-dark">
            <tr>
                <th>Order ID</th>
                <th>Customer Name</th>
                <th>Product Name</th>
                <th>Quantity</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.OrderID</td>
                    <td>@(item.User != null ? item.User.FullName : "N/A")</td>
                    <td>@(item.Product != null ? item.Product.ProductName : "N/A")</td>
                    <td>@item.Quantity</td>
                </tr>
            }
        </tbody>
    </table>
</div>
