@model List<Web_project_as.Models.Order>
@{
    ViewData["Title"] = "Orders";
}
<h2>Orders</h2>
<table>
    <tr>
        <th>Order ID</th>
        <th>Customer</th>
        <th>Product</th>
        <th>Quantity</th>
        <th>Total</th>
    </tr>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.OrderID</td>
            <td>@item.User.FullName</td>
            <td>@item.Product.ProductName</td>
            <td>@item.Quantity</td>
            <td>$@item.TotalPrice</td>
        </tr>
    }
</table>
