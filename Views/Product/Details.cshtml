@model Web_project_as.Models.Product
@{
    ViewData["Title"] = "Product Details";
}
<h2>Product Details</h2>
<p>ID: @Model.ProductID</p>
<p>Name: @Model.ProductName</p>
<p>Price: $@Model.Price</p>
<p>Quantity: @Model.Quantity</p>
<p>Description: @(Model.Description ?? "No description")</p>
<a asp-action="ShowAllProudect" class="btn">Back to Products</a>
